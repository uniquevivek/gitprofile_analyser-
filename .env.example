# Server Configuration
PORT=3000

# Database Configuration
# Supported types: mysql, sqlite
DB_TYPE=sqlite

# MySQL configuration (only used if DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=github_analyzer
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# SQLite configuration (only used if DB_TYPE=sqlite)
DB_FILE=database.sqlite

# GitHub API Configuration (Optional but highly recommended)
# Provide a Personal Access Token (PAT) to increase rate limit from 60 to 5000 requests/hr
GITHUB_TOKEN=
